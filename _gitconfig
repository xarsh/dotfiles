[help]
	autocorrect = prompt
[core]
	quotepath = false
	fileMode = false
	excludesfile = ~/.gitignore_global
	editor = code --wait
[user]
	email = xarsh@outlook.com
	name = Takao Naito
[init]
	defaultBranch = main
[pull]
	rebase = true
[fetch]
	prune = true
[push]
	autoSetupRemote = true
[rebase]
	autostash = true
	autosquash = true
[merge]
	conflictstyle = zdiff3
[rerere]
	enabled = true
[url "git@github.com:"]
	pushinsteadof = https://github.com/
[url "https://"]
	insteadOf = git://
[alias]
	unstage = reset HEAD
